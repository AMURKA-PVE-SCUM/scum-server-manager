{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../../dist/main",
    "rootDir": ".",
    "sourceMap": false,
    "declaration": false
  },
  "include": ["./**/*.ts", "../types/**/*.d.ts"]
}
