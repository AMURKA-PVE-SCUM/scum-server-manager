{
  "name": "scum-server-manager",
  "version": "1.0.0",
  "description": "SCUM Dedicated Server Manager — управление, мониторинг и настройка SCUM сервера",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p src/main/tsconfig.json && electron dist/main/index.js",
    "dev:main:watch": "concurrently \"tsc -p src/main/tsconfig.json --watch\" \"wait-on dist/main/index.js && electron dist/main/index.js\"",
    "dev:renderer": "vite",
    "dev:unified": "concurrently \"npm run dev:main:watch\" \"npm run dev:renderer\" --kill-others",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "lint": "eslint src/**/*.{ts,tsx}",
    "typecheck": "tsc --noEmit -p src/renderer/tsconfig.json && tsc --noEmit -p src/main/tsconfig.json"
  },
  "keywords": [
    "scum",
    "server",
    "manager",
    "dedicated-server"
  ],
  "author": "SCUM Server Manager",
  "license": "MIT",
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/node": "^20.10.0",
    "@types/ps-list": "^6.0.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^27.1.3",
    "electron-builder": "^24.6.4",
    "electron-packager": "^17.1.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.1",
    "@mui/material": "^5.15.1",
    "@mui/x-data-grid": "^6.18.1",
    "chokidar": "^4.0.3",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.1.1",
    "ini": "^4.1.1",
    "ps-list": "^7.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1"
  },
  "build": {
    "appId": "com.scumservermanager.app",
    "productName": "SCUM Server Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "*.exe"
        ]
      }
    ],
    "win": {
      "target": "portable"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
